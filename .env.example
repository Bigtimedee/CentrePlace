# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk custom domain (used by the proxy route at /clerk/[...path])
# Set this to your Clerk Frontend API domain in the Clerk dashboard
NEXT_PUBLIC_CLERK_DOMAIN=clerk.gpretire.com

# Clerk proxy URL — routes all Clerk browser API calls and OAuth callbacks
# through the Next.js /clerk/[...path] proxy instead of clerk.gpretire.com directly.
# This is required because the clerk.gpretire.com custom domain SSL cert may not yet
# be provisioned. ClerkProvider reads this automatically via NEXT_PUBLIC_CLERK_PROXY_URL.
NEXT_PUBLIC_CLERK_PROXY_URL=https://gpretire.com/clerk

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Google OAuth (configured via the Clerk Dashboard, not directly here)
# To enable Google login:
#   1. Go to Clerk Dashboard → User & Authentication → Social Connections
#   2. Enable Google and set it as a social connection
#   3. In Google Cloud Console, open your OAuth 2.0 client and add this
#      Authorized redirect URI (the proxy path, NOT clerk.gpretire.com):
#      - Authorized redirect URI: https://gpretire.com/clerk/v1/oauth_callback
#   4. Paste the Google Client ID and Secret into the Clerk Dashboard
# No additional environment variables are required in this file for Google OAuth.

# Application
NEXT_PUBLIC_APP_URL=https://gpretire.com

# Database
DATABASE_URL=postgresql://...

# Admin
ADMIN_EMAIL=admin@example.com

# ─── Financial Data APIs ────────────────────────────────────────────────────
# Financial Modeling Prep — Wall Street analyst consensus, price targets, fundamentals
# Free tier: 250 requests/day  |  Get key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Finnhub — news sentiment and recent headlines
# Free tier: 60 requests/min  |  Get key at: https://finnhub.io/register
FINNHUB_API_KEY=

# Alpha Vantage — financial news sentiment scoring
# Free tier: 25 requests/day  |  Get key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
